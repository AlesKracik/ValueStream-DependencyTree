{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Value Stream Dashboard API Payload",
    "description": "JSON Schema defining the exact structure required for the Value Stream Dependency Tree visualization.",
    "type": "object",
    "required": [
        "settings",
        "customers",
        "workItems",
        "teams",
        "epics",
        "sprints",
        "dashboards"
    ],
    "properties": {
        "settings": {
            "type": "object",
            "required": [
                "jira_base_url",
                "jira_api_version"
            ],
            "properties": {
                "jira_base_url": {
                    "type": "string",
                    "format": "uri"
                },
                "jira_api_version": {
                    "type": "string",
                    "enum": [
                        "2",
                        "3"
                    ]
                },
                "jira_api_token": {
                    "type": "string"
                },
                "mongo_uri": { "type": "string" },
                "mongo_db": { "type": "string" },
                "mongo_auth_method": { "type": "string", "enum": ["scram", "aws", "oidc"] },
                "fiscal_year_start_month": { "type": "integer", "minimum": 1, "maximum": 12 },
                "sprint_duration_days": { "type": "integer", "minimum": 1 }
            }
        },
        "customers": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "name",
                    "existing_tcv",
                    "potential_tcv"
                ],
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "existing_tcv": {
                        "type": "number",
                        "minimum": 0
                    },
                    "existing_tcv_valid_from": {
                        "type": "string",
                        "format": "date"
                    },
                    "potential_tcv": {
                        "type": "number",
                        "minimum": 0
                    },
                    "tcv_history": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": ["id", "value", "valid_from"],
                            "properties": {
                                "id": { "type": "string" },
                                "value": { "type": "number", "minimum": 0 },
                                "valid_from": { "type": "string", "format": "date" }
                            }
                        }
                    }
                }
            }
        },
        "workItems": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "name",
                    "total_effort_mds",
                    "customer_targets",
                    "score"
                ],
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "description": {
                        "type": "string"
                    },
                    "total_effort_mds": {
                        "type": "number",
                        "minimum": 0
                    },
                    "score": {
                        "type": "number"
                    },
                    "released_in_sprint_id": {
                        "type": "string"
                    },
                    "all_customers_target": {
                        "type": "object",
                        "required": [
                            "tcv_type"
                        ],
                        "properties": {
                            "tcv_type": {
                                "type": "string",
                                "enum": [
                                    "existing",
                                    "potential"
                                ]
                            },
                            "priority": {
                                "type": "string",
                                "enum": [
                                    "Must-have",
                                    "Should-have",
                                    "Nice-to-have"
                                ]
                            }
                        }
                    },
                    "customer_targets": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": [
                                "customer_id",
                                "tcv_type"
                            ],
                            "properties": {
                                "customer_id": {
                                    "type": "string"
                                },
                                "tcv_type": {
                                    "type": "string",
                                    "enum": [
                                        "existing",
                                        "potential"
                                    ]
                                },
                                "priority": {
                                    "type": "string",
                                    "enum": [
                                        "Must-have",
                                        "Should-have",
                                        "Nice-to-have"
                                    ]
                                },
                                "tcv_history_id": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            }
        },
        "teams": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "name",
                    "total_capacity_mds"
                ],
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "total_capacity_mds": {
                        "type": "number",
                        "minimum": 0
                    },
                    "country": {
                        "type": "string"
                    },
                    "jira_team_id": {
                        "type": "string"
                    },
                    "sprint_capacity_overrides": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "number",
                            "minimum": 0
                        }
                    }
                }
            }
        },
        "epics": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "jira_key",
                    "team_id",
                    "effort_md"
                ],
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "jira_key": {
                        "type": "string"
                    },
                    "work_item_id": {
                        "type": "string"
                    },
                    "team_id": {
                        "type": "string"
                    },
                    "effort_md": {
                        "type": "number",
                        "minimum": 0
                    },
                    "target_start": {
                        "type": "string",
                        "format": "date"
                    },
                    "target_end": {
                        "type": "string",
                        "format": "date"
                    },
                    "sprint_effort_overrides": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "number",
                            "minimum": 0
                        }
                    },
                    "dependencies": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "epic_id": {
                                    "type": "string"
                                },
                                "dependency_type": {
                                    "type": "string",
                                    "enum": [
                                        "FS",
                                        "FF"
                                    ]
                                }
                            },
                            "required": [
                                "epic_id",
                                "dependency_type"
                            ]
                        }
                    }
                }
            }
        },
        "sprints": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "name",
                    "start_date",
                    "end_date"
                ],
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "start_date": {
                        "type": "string",
                        "format": "date"
                    },
                    "end_date": {
                        "type": "string",
                        "format": "date"
                    },
                    "quarter": { "type": "string" }
                }
            }
        },
        "dashboards": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "name",
                    "description",
                    "parameters"
                ],
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "description": {
                        "type": "string"
                    },
                    "parameters": {
                        "type": "object",
                        "required": [
                            "customerFilter",
                            "workItemFilter",
                            "releasedFilter",
                            "minTcvFilter",
                            "minScoreFilter",
                            "teamFilter",
                            "epicFilter"
                        ],
                        "properties": {
                            "customerFilter": { "type": "string" },
                            "workItemFilter": { "type": "string" },
                            "releasedFilter": { "type": "string", "enum": ["all", "released", "unreleased"] },
                            "minTcvFilter": { "type": "string" },
                            "minScoreFilter": { "type": "string" },
                            "teamFilter": { "type": "string" },
                            "epicFilter": { "type": "string" },
                            "startSprintId": { "type": "string" },
                            "endSprintId": { "type": "string" }
                        }
                    }
                }
            }
        }
    }
}
