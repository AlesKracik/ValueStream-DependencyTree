{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Value Stream Dashboard API Payload",
    "description": "JSON Schema defining the exact structure required for the Value Stream Dependency Tree visualization.",
    "type": "object",
    "required": [
        "settings",
        "customers",
        "workItems",
        "teams",
        "epics",
        "sprints"
    ],
    "properties": {
        "settings": {
            "type": "object",
            "required": [
                "jira_base_url",
                "jira_api_version"
            ],
            "properties": {
                "jira_base_url": {
                    "type": "string",
                    "format": "uri"
                },
                "jira_api_version": {
                    "type": "string",
                    "enum": [
                        "2",
                        "3"
                    ]
                },
                "jira_api_token": {
                    "type": "string"
                }
            }
        },
        "customers": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "name",
                    "existing_tcv",
                    "potential_tcv"
                ],
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "existing_tcv": {
                        "type": "number",
                        "minimum": 0
                    },
                    "potential_tcv": {
                        "type": "number",
                        "minimum": 0
                    }
                }
            }
        },
        "workItems": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "name",
                    "total_effort_mds",
                    "customer_targets"
                ],
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "total_effort_mds": {
                        "type": "number",
                        "minimum": 0
                    },
                    "released_in_sprint_id": {
                        "type": "string"
                    },
                    "all_customers_target": {
                        "type": "object",
                        "required": [
                            "tcv_type"
                        ],
                        "properties": {
                            "tcv_type": {
                                "type": "string",
                                "enum": [
                                    "existing",
                                    "potential"
                                ]
                            },
                            "priority": {
                                "type": "string",
                                "enum": [
                                    "Must-have",
                                    "Should-have",
                                    "Nice-to-have"
                                ]
                            }
                        }
                    },
                    "customer_targets": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": [
                                "customer_id",
                                "tcv_type"
                            ],
                            "properties": {
                                "customer_id": {
                                    "type": "string"
                                },
                                "tcv_type": {
                                    "type": "string",
                                    "enum": [
                                        "existing",
                                        "potential"
                                    ]
                                },
                                "priority": {
                                    "type": "string",
                                    "enum": [
                                        "Must-have",
                                        "Should-have",
                                        "Nice-to-have"
                                    ],
                                    "description": "Defaults to Must-have if omitted."
                                }
                            }
                        }
                    }
                }
            }
        },
        "teams": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "name",
                    "total_capacity_mds"
                ],
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "total_capacity_mds": {
                        "type": "number",
                        "minimum": 0
                    },
                    "country": {
                        "type": "string",
                        "description": "ISO Country Code (e.g. US, CZ, GB) for holiday calculations."
                    },
                    "jira_team_id": {
                        "type": "string"
                    },
                    "sprint_capacity_overrides": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "number",
                            "minimum": 0
                        }
                    }
                }
            }
        },
        "epics": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "jira_key",
                    "team_id",
                    "remaining_md"
                ],
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string",
                        "description": "Optional custom name for the epic. Falls back to parent Work Item name."
                    },
                    "jira_key": {
                        "type": "string"
                    },
                    "work_item_id": {
                        "type": "string"
                    },
                    "team_id": {
                        "type": "string"
                    },
                    "remaining_md": {
                        "type": "number",
                        "minimum": 0
                    },
                    "target_start": {
                        "type": "string",
                        "format": "date",
                        "description": "YYYY-MM-DD"
                    },
                    "target_end": {
                        "type": "string",
                        "format": "date",
                        "description": "YYYY-MM-DD"
                    },
                    "sprint_effort_overrides": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "number",
                            "minimum": 0
                        }
                    },
                    "dependencies": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "epic_id": {
                                    "type": "string"
                                },
                                "dependency_type": {
                                    "type": "string",
                                    "enum": [
                                        "FS",
                                        "FF"
                                    ]
                                }
                            },
                            "required": [
                                "epic_id",
                                "dependency_type"
                            ]
                        }
                    }
                }
            }
        },
        "sprints": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "name",
                    "start_date",
                    "end_date"
                ],
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "start_date": {
                        "type": "string",
                        "format": "date",
                        "description": "YYYY-MM-DD"
                    },
                    "end_date": {
                        "type": "string",
                        "format": "date",
                        "description": "YYYY-MM-DD"
                    }
                }
            }
        }
    }
}
