{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "ValueStream API Payload",
    "description": "JSON Schema defining the exact structure required for the ValueStream Dependency Tree visualization.",
    "type": "object",
    "required": [
        "settings",
        "customers",
        "workItems",
        "teams",
        "issues",
        "sprints",
        "valueStreams"
    ],
    "properties": {
        "settings": {
            "type": "object",
            "required": [
                "general",
                "persistence",
                "jira",
                "ai"
            ],
            "properties": {
                "general": {
                    "type": "object",
                    "required": ["fiscal_year_start_month", "sprint_duration_days"],
                    "properties": {
                        "fiscal_year_start_month": { "type": "integer", "minimum": 1, "maximum": 12 },
                        "sprint_duration_days": { "type": "integer", "minimum": 1 },
                        "theme": { "type": "string", "enum": ["dark", "filips"] }
                    }
                },
                "persistence": {
                    "type": "object",
                    "required": ["mongo"],
                    "properties": {
                        "mongo": {
                            "type": "object",
                            "required": ["app", "customer"],
                            "properties": {
                                "app": { "$ref": "#/definitions/mongoConfig" },
                                "customer": { 
                                    "allOf": [
                                        { "$ref": "#/definitions/mongoConfig" },
                                        {
                                            "type": "object",
                                            "properties": {
                                                "collection": { "type": "string" },
                                                "custom_query": { "type": "string" }
                                            }
                                        }
                                    ]
                                }
                            }
                        }
                    }
                },
                "jira": {
                    "type": "object",
                    "required": ["base_url", "api_version"],
                    "properties": {
                        "base_url": { "type": "string", "format": "uri" },
                        "api_version": { "type": "string", "enum": ["2", "3"] },
                        "api_token": { "type": "string" },
                        "customer": {
                            "type": "object",
                            "properties": {
                                "jql_new": { "type": "string" },
                                "jql_in_progress": { "type": "string" },
                                "jql_noop": { "type": "string" }
                            }
                        }
                    }
                },
                "ai": {
                    "type": "object",
                    "required": ["provider"],
                    "properties": {
                        "provider": { "type": "string", "enum": ["openai", "gemini", "anthropic", "augment", "glean"] },
                        "api_key": { "type": "string" },
                        "model": { "type": "string" },
                        "support": {
                            "type": "object",
                            "properties": {
                                "prompt": { "type": "string" }
                            }
                        },
                        "glean_url": { "type": "string" },
                        "glean_state": {
                            "type": "object",
                            "properties": {
                                "tokens": {
                                    "type": "object",
                                    "additionalProperties": {
                                        "type": "object",
                                        "properties": {
                                            "access_token": { "type": "string" },
                                            "refresh_token": { "type": "string" },
                                            "expires_at": { "type": "number" },
                                            "client_id": { "type": "string" },
                                            "client_secret": { "type": "string" },
                                            "token_endpoint": { "type": "string" }
                                        }
                                    }
                                },
                                "clients": {
                                    "type": "object",
                                    "additionalProperties": {
                                        "type": "object",
                                        "properties": {
                                            "client_id": { "type": "string" },
                                            "client_secret": { "type": "string" },
                                            "registration_client_uri": { "type": "string" },
                                            "registration_access_token": { "type": "string" },
                                            "registration_endpoint": { "type": "string" },
                                            "token_endpoint": { "type": "string" },
                                            "authorization_endpoint": { "type": "string" }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "customers": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "name",
                    "existing_tcv",
                    "potential_tcv"
                ],
                "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" },
                    "customer_id": { "type": "string" },
                    "existing_tcv": { "type": "number", "minimum": 0 },
                    "existing_tcv_valid_from": { "type": "string", "format": "date" },
                    "existing_tcv_duration_months": { "type": "number", "minimum": 0 },
                    "potential_tcv": { "type": "number", "minimum": 0 },
                    "potential_tcv_valid_from": { "type": "string", "format": "date" },
                    "potential_tcv_duration_months": { "type": "number", "minimum": 0 },
                    "tcv_history": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": ["id", "value", "valid_from"],
                            "properties": {
                                "id": { "type": "string" },
                                "value": { "type": "number", "minimum": 0 },
                                "valid_from": { "type": "string", "format": "date" },
                                "duration_months": { "type": "number", "minimum": 0 }
                            }
                        }
                    },
                    "support_issues": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": ["id", "description", "status"],
                            "properties": {
                                "id": { "type": "string" },
                                "description": { "type": "string" },
                                "status": { 
                                    "type": "string", 
                                    "enum": ["to do", "work in progress", "noop", "waiting for customer", "waiting for other party", "done"]                                },
                                "related_jiras": {
                                    "type": "array",
                                    "items": { "type": "string" }
                                },
                                "expiration_date": {
                                    "type": "string",
                                    "format": "date"
                                },
                                "created_at": { "type": "string", "format": "date-time" },
                                "updated_at": { "type": "string", "format": "date-time" }
                            }
                        }
                    },
                    "jira_support_issues": {
                        "type": "array",
                        "items": { "$ref": "#/definitions/jiraIssue" }
                    }
                }
            }
        },
        "workItems": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "name",
                    "total_effort_mds",
                    "customer_targets",
                    "score"
                ],
                "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" },
                    "description": { "type": "string" },
                    "status": { "type": "string", "enum": ["Backlog", "Planning", "Development", "Done"] },
                    "total_effort_mds": { "type": "number", "minimum": 0 },
                    "score": { "type": "number" },
                    "released_in_sprint_id": { "type": "string" },
                    "all_customers_target": {
                        "type": "object",
                        "required": ["tcv_type"],
                        "properties": {
                            "tcv_type": { "type": "string", "enum": ["existing", "potential"] },
                            "priority": { "type": "string", "enum": ["Must-have", "Should-have", "Nice-to-have"] }
                        }
                    },
                    "customer_targets": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": ["customer_id", "tcv_type"],
                            "properties": {
                                "customer_id": { "type": "string" },
                                "tcv_type": { "type": "string", "enum": ["existing", "potential"] },
                                "priority": { "type": "string", "enum": ["Must-have", "Should-have", "Nice-to-have"] },
                                "tcv_history_id": { "type": "string" }
                            }
                        }
                    }
                }
            }
        },
        "teams": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["id", "name", "total_capacity_mds"],
                "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" },
                    "total_capacity_mds": { "type": "number", "minimum": 0 },
                    "country": { "type": "string" },
                    "jira_team_id": { "type": "string" },
                    "sprint_capacity_overrides": {
                        "type": "object",
                        "additionalProperties": { "type": "number", "minimum": 0 }
                    }
                }
            }
        },
        "issues": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["id", "jira_key", "team_id", "effort_md"],
                "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" },
                    "jira_key": { "type": "string" },
                    "work_item_id": { "type": "string" },
                    "team_id": { "type": "string" },
                    "effort_md": { "type": "number", "minimum": 0 },
                    "target_start": { "type": "string", "format": "date" },
                    "target_end": { "type": "string", "format": "date" },
                    "external_url": { "type": "string" },
                    "sprint_effort_overrides": {
                        "type": "object",
                        "additionalProperties": { "type": "number", "minimum": 0 }
                    },
                    "dependencies": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": ["issue_id", "dependency_type"],
                            "properties": {
                                "issue_id": { "type": "string" },
                                "dependency_type": { "type": "string", "enum": ["FS", "FF"] }
                            }
                        }
                    }
                }
            }
        },
        "sprints": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["id", "name", "start_date", "end_date"],
                "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" },
                    "start_date": { "type": "string", "format": "date" },
                    "end_date": { "type": "string", "format": "date" },
                    "quarter": { "type": "string" },
                    "is_archived": { "type": "boolean" }
                }
            }
        },
        "valueStreams": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["id", "name", "description", "parameters"],
                "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" },
                    "description": { "type": "string" },
                    "parameters": {
                        "type": "object",
                        "required": [
                            "customerFilter", "workItemFilter", "releasedFilter", 
                            "minTcvFilter", "minScoreFilter", "teamFilter", "issueFilter"
                        ],
                        "properties": {
                            "customerFilter": { "type": "string" },
                            "workItemFilter": { "type": "string" },
                            "releasedFilter": { "type": "string", "enum": ["all", "released", "unreleased"] },
                            "minTcvFilter": { "type": "string" },
                            "minScoreFilter": { "type": "string" },
                            "teamFilter": { "type": "string" },
                            "issueFilter": { "type": "string" },
                            "startSprintId": { "type": "string" },
                            "endSprintId": { "type": "string" }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "jiraIssue": {
            "type": "object",
            "required": ["key", "summary", "status", "priority", "url", "last_updated"],
            "properties": {
                "key": { "type": "string" },
                "summary": { "type": "string" },
                "status": { "type": "string" },
                "priority": { "type": "string" },
                "url": { "type": "string" },
                "last_updated": { "type": "string", "format": "date-time" },
                "category": { "type": "string", "enum": ["new", "in_progress", "noop"] }
            }
        },
        "mongoConfig": {
            "type": "object",
            "required": ["uri", "db", "use_proxy", "auth"],
            "properties": {
                "uri": { "type": "string" },
                "db": { "type": "string" },
                "use_proxy": { "type": "boolean" },
                "tunnel_name": { "type": "string" },
                "auth": {
                    "type": "object",
                    "required": ["method"],
                    "properties": {
                        "method": { "type": "string", "enum": ["scram", "aws", "oidc"] },
                        "aws_auth_type": { "type": "string", "enum": ["static", "role"] },
                        "aws_access_key": { "type": "string" },
                        "aws_secret_key": { "type": "string" },
                        "aws_session_token": { "type": "string" },
                        "aws_role_arn": { "type": "string" },
                        "aws_external_id": { "type": "string" },
                        "aws_role_session_name": { "type": "string" },
                        "aws_profile": { "type": "string" },
                        "aws_sso_start_url": { "type": "string" },
                        "aws_sso_region": { "type": "string" },
                        "aws_sso_account_id": { "type": "string" },
                        "aws_sso_role_name": { "type": "string" },
                        "oidc_token": { "type": "string" }
                    }
                }
            }
        }
    }
}
