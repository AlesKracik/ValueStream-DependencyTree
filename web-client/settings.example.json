{
  "jira_base_url": "https://your-domain.atlassian.net",
  "jira_api_version": "3",
  "jira_api_token": "YOUR_JIRA_PAT",
  "mongo_uri": "mongodb://localhost:27017",
  "mongo_db": "valuestream",
  "mongo_auth_method": "scram",
  "mongo_create_if_not_exists": true,
  "customer_jql_new": "project = PROJ AND status = 'New'",
  "customer_jql_in_progress": "project = PROJ AND status = 'In Progress'",
  "customer_jql_noop": "project = PROJ AND status = 'Closed'",
  "fiscal_year_start_month": 1,
  "sprint_duration_days": 14
}
