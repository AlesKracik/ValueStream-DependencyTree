# --- Application Security ---
# Set a secure password to protect your Settings and Data. 
# Recommended: Do NOT use quotes around the value.
ADMIN_SECRET=your-secure-password

# --- SOCKS Proxy Configuration ---
# The application uses a SOCKS5 proxy to route MongoDB traffic (supports SRV/Atlas).

# [1] LOCAL DEVELOPMENT (Native)
# Set to 127.0.0.1 and run: ./scripts/start-tunnel.ps1
SOCKS_PROXY_HOST=127.0.0.1
SOCKS_PROXY_PORT=1080

# [2] DOCKER (Standard Sidecar) - RECOMMENDED
# The app uses the 'ssh-proxy' service from docker-compose.yml automatically.
# SOCKS_PROXY_HOST=ssh-proxy
# COMPOSE_PROFILES=ssh-proxy

# [3] DOCKER VPN WORKAROUND (MacOS/Windows)
# Use if your VPN blocks the Docker VM from making outbound SSH connections.
# Start a tunnel on your Mac host and connect via 'host.docker.internal'.
# SOCKS_PROXY_HOST=host.docker.internal
# COMPOSE_PROFILES= # Ensure this is empty for Scenario C

# --- SSH Tunnel Configuration (Used by Sidecar & Local Scripts) ---
# Required to establish the tunnel to your MongoDB bastion/cluster.
SSH_USER=your-ssh-username
SSH_HOST=ssh.bastion.com

# Path to your private key on the HOST machine.
# Windows Example: C:/Users/yourname/.ssh/id_rsa
# MacOS/Linux Example: ~/.ssh/id_rsa
SSH_KEY_PATH=~/.ssh/id_rsa
