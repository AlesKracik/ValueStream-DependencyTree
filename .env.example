# --- Application Auth ---
ADMIN_SECRET=your-secure-password

# --- SSH Tunneling (Global / Common) ---
# The app supports three networking scenarios: A (Local), B (Sidecar - Recommended), and C (VPN Workaround); see README.md for details.
# Set host to 'ssh-proxy' for Docker Sidecar (Scenario B)
# Set host to 'host.docker.internal' for Host-started tunnels (Scenario C)
# Set host to 'localhost' for pure local Node development (Scenario A)
SOCKS_PROXY_HOST=localhost
SSH_KEY_PATH=~/.ssh/id_rsa

# --- Tunnel 1: Application DB (Example) ---
APP_SSH_USER=user1
APP_SSH_HOST=bastion-app.example.com
APP_SOCKS_PORT=1080

# --- Tunnel 2: Customer DB (Example) ---
CUSTOMER_SSH_USER=user2
CUSTOMER_SSH_HOST=bastion-customer.example.com
CUSTOMER_SOCKS_PORT=1081

# --- Docker Compose Specific ---
# Set to 'ssh-proxy' to enable the sidecar service
COMPOSE_PROFILES=ssh-proxy

# --- Note on Application Settings ---
# MongoDB URI, DB Name, and Jira credentials are NOT managed in .env.
# They are configured via the in-app Settings UI and stored in settings.json.
