# ==============================================================================
# AUTHENTICATION
# ==============================================================================
ADMIN_SECRET=your-secure-password


# ==============================================================================
# TUNNEL TARGETS (Shared by all scenarios)
# Define WHERE you are connecting and WHICH keys to use.
# ==============================================================================

# --- Tunnel 1: Application DB ---
APP_SSH_USER=user1
APP_SSH_HOST=bastion-app.example.com
APP_SOCKS_PORT=1080
APP_SSH_KEY_PATH=~/.ssh/id_rsa_app

# --- Tunnel 2: Customer DB ---
CUSTOMER_SSH_USER=user2
CUSTOMER_SSH_HOST=bastion-customer.example.com
CUSTOMER_SOCKS_PORT=1081
CUSTOMER_SSH_KEY_PATH=~/.ssh/id_rsa_customer


# ==============================================================================
# NETWORKING SCENARIOS (Pick ONE and uncomment relevant lines)
# ==============================================================================

# ------------------------------------------------------------------------------
# SCENARIO A: Local Development (Native Node.js)
# Use this when running 'npm run dev' directly on your host machine.
# ------------------------------------------------------------------------------
SOCKS_PROXY_HOST=localhost
# To start: .\scripts\start-tunnel.ps1 all


# ------------------------------------------------------------------------------
# SCENARIO B: Docker Sidecar (Recommended)
# Use this with 'docker-compose up'. The sidecar container handles the tunnels.
# ------------------------------------------------------------------------------
# SOCKS_PROXY_HOST=ssh-proxy
# COMPOSE_PROFILES=ssh-proxy
# SSH_DIR=~/.ssh         # Path on HOST to your .ssh folder for mounting


# ------------------------------------------------------------------------------
# SCENARIO C: VPN Workaround (Host Tunnel + Docker App)
# Use this if corporate VPN blocks Docker outbound SSH, but allows the Host.
# ------------------------------------------------------------------------------
# 1. Start tunnel on Host: .\scripts\start-tunnel.ps1 all
# 2. Set these variables:
# SOCKS_PROXY_HOST=host.docker.internal
# COMPOSE_PROFILES=      # Ensure sidecar is disabled
