{
  "general": {
    "fiscal_year_start_month": 1,
    "sprint_duration_days": 14
  },
  "persistence": {
    "mongo": {
      "app": {
        "uri": "mongodb://localhost:27017",
        "db": "valueStream",
        "use_proxy": false,
        "tunnel_name": "app",
        "auth": {
          "method": "scram"
        }
      },
      "customer": {
        "uri": "mongodb://localhost:27017",
        "db": "customers",
        "use_proxy": false,
        "tunnel_name": "customer",
        "collection": "Customers",
        "custom_query": "",
        "auth": {
          "method": "scram"
        }
      }
    }
  },
  "jira": {
    "base_url": "https://your-domain.atlassian.net",
    "api_version": "3",
    "api_token": "",
    "customer": {
      "jql_new": "labels = '{{CUSTOMER_ID}}' AND status = 'New'",
      "jql_in_progress": "labels = '{{CUSTOMER_ID}}' AND status = 'In Progress'",
      "jql_noop": "labels = '{{CUSTOMER_ID}}' AND status = 'Blocked'"
    }
  },
  "ai": {
    "provider": "openai",
    "api_key": "",
    "model": "gpt-4-turbo",
    "support": {
      "prompt": "Analyze the following Slack conversations and extract customer issues. Your response MUST be a single JSON object matching this schema. IMPORTANT: DO NOT use ellipses (...) in your response; provide complete data or omit the field if unknown. Schema: {\"customers\": [{\"name\": \"string\", \"issues\": [{\"summary\": \"string\", \"impact\": \"string\", \"rootCause\": \"string\"}]}]}"
    }
  }
}
